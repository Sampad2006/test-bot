{
  "name": "wellness-ai",
  "version": "1.0.0",
  "description": "AI in Mental Health & Emotional Support — Track B",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "eval:promptfoo": "WELLNESS_WS_URL=${WELLNESS_WS_URL:-ws://localhost:8000/chat} WELLNESS_EVAL_TIMEOUT_MS=${WELLNESS_EVAL_TIMEOUT_MS:-45000} npx promptfoo@latest eval -c eval/promptfoo/promptfooconfig.yaml -j 1",
    "eval:promptfoo:watch": "WELLNESS_WS_URL=${WELLNESS_WS_URL:-ws://localhost:8000/chat} WELLNESS_EVAL_TIMEOUT_MS=${WELLNESS_EVAL_TIMEOUT_MS:-45000} npx promptfoo@latest watch -c eval/promptfoo/promptfooconfig.yaml",
    "eval:promptfoo:view": "npx promptfoo@latest view",
    "eval:deepeval": "python3 eval/deepeval/run_deepeval.py",
    "eval:dataset:build": "python3 eval/datasets/build_eval_set.py"
  },
  "dependencies": {
    "@getzep/zep-cloud": "^2.7.0",
    "@google/generative-ai": "^0.21.0",
    "@langchain/core": "^0.3.25",
    "@langchain/langgraph": "^0.2.34",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "groq-sdk": "^0.9.1",
    "mongodb": "^6.21.0",
    "uuid": "^9.0.1",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.1",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.13",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
