# === LLM APIs ===
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# === Memory ===
ZEP_API_KEY=your_zep_api_key_here
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/wellness_db?retryWrites=true&w=majority

# === App Config ===
PORT=8000
NODE_ENV=development
LOG_LEVEL=info

# === Model Config ===
GROQ_MODEL=llama-3.1-8b-instant
ROUTER_MODEL=gemini-2.5-flash-latest
EMOGUARD_MODEL=llama-3.1-8b-instant
